{
  "version": 2,
  "framework": null,
  "installCommand": "pip install -r requirements.txt",
  "buildCommand": "sh build.sh",
  "rewrites": [
    {
      "source": "/static/(.*)",
      "destination": "/static/$1"
    },
    {
      "source": "/(.*)",
      "destination": "permutas_site/wsgi.py"
    }
  ]
}
